{
  "collections": [],
  "enable_format": true,
  "enable_hover": true,
  "enable_snippets": true,
  "enable_semantic_tokens": true,
  "enable_document_symbols": true,
  "enable_fake_methods": false,
  "enable_inlay_hints": true,
  "enable_procedure_snippet": true,
  "enable_checker_only_saved": true,
  "enable_references": false,
  "enable_rename": true,
  "checker_args": "-vet-unused -vet-unused-variables -vet-unused-imports -vet-shadowing -vet-style -vet-semicolon -vet-cast",
  "verbose": false,
  "profiles": [
    {
      "name": "src_folder_profile",
      "os": "windows",
      "checker_path": [
        "src"
      ]
    },
    {
      "name": "source_folder_profile",
      "os": "windows",
      "checker_path": [
        "source"
      ]
    },
    {
      "name": "root_folder_profile",
      "os": "windows",
      "checker_path": [
        "."
      ]
    }
  ],
  "profile": "source_folder_profile"
}