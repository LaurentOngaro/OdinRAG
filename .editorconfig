# EditorConfig - OdinRAG
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false
indent_size = 2

[*.{json,yaml,yml,toml}]
indent_size = 2

[*.py]
indent_size = 4
max_line_length = 150

[*.odin]
indent_style = space
indent_size = 2
max_line_length = 150

[Makefile]
indent_style = tab
