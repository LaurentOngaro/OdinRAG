{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "Minimax/Minimax M3",
  "small_model": "anthropic/claude-haiku-4-5",
  "default_agent": "code",
  "instructions": [
    "AGENTS.md",
    "README.md",
    "TODO.md",
    ".kilo/agents/odin-gamedev.md",
    "code/projects/PVG03_RPG/AGENTS.md",
    "code/projects/PVG03_RPG/.kilo/agents/odin-project.md"
  ],
  "skills": {
    "paths": [
      ".kilo/skills"
    ]
  },
  "permission": {
    "bash": {
      "python _Helpers/scripts/scrappers/scrape_*.py *": "allow",
      "python _Helpers/scripts/scrappers/download_*.py *": "allow",
      "python _Helpers/scripts/fixes/book_html_to_md.py *": "allow",
      "python _Helpers/scripts/fixes/format_odin_in_files.py *": "allow",
      "python _Helpers/scripts/fixes/fix_mojibake.py *": "allow",
      "python _Helpers/scripts/fixes/reflow_md.py *": "allow",
      "python _Helpers/scripts/diagnostic/audit_public_safety.py *": "allow",
      "python _Helpers/scripts/diagnostic/auditReadmeCoherence.py *": "allow",
      "python _Helpers/scripts/fixes/lint_pylance.py *": "allow",
      "python _Helpers/scripts/indexing/build_kb_index.py *": "allow",
      "& '<PATH_TO_ODINFMT>\\odinfmt.exe' *": "allow",
      "Get-ChildItem *": "allow",
      "Get-Content *": "allow",
      "Test-Path *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "Remove-Item -Recurse -Force *": "deny",
      "rm -rf *": "deny",
      "git push --force *": "deny"
    },
    "edit": {
      "odin-knowledge-base/courses/**/!README.md": "deny",
      "odin-knowledge-base/docs/**/!README.md": "deny",
      "_Helpers/logs/**": "deny",
      "code/projects/PVG03_RPG/**": "deny",
      "**/.private/**": "deny",
      "**/__pycache__/**": "deny"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "snapshot": true
}